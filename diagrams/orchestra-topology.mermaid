graph TD
    User([User]) -->|request| Larry[Larry<br/>Chief of Staff]

    subgraph Core Team
        Larry -->|research task| Merlin[Merlin<br/>Senior Researcher]
        Larry -->|hire request| Nolan[Nolan<br/>Head of AI Talent]
        Larry -->|technical task| KAI[KAI<br/>Technical Engineer]
        Merlin -->|Hire Brief| Nolan
    end

    subgraph Your Agents
        Larry -->|domain task| A1[Agent 1<br/>Your Specialist]
        Larry -->|writing task| A2[Agent 2<br/>Your Writer]
        Larry -->|analysis task| A3[Agent 3<br/>Your Analyst]
        Larry -.->|future agents| AN[Agent N<br/>...]
    end

    Nolan -->|creates| A1
    Nolan -->|creates| A2
    Nolan -->|creates| A3

    subgraph Workflow
        OI[Owner's Inbox] -->|input| Larry
        A1 -->|output| TI[Team Inbox]
        A2 -->|output| TI
        A3 -->|output| TI
        KAI -->|output| TI
        Merlin -->|output| TI
        TI -->|approved| CW[Completed Work]
    end

    User -->|reviews| TI
    User -->|approves| CW

    style Larry fill:#e6b800,stroke:#333,color:#000
    style Merlin fill:#4a90d9,stroke:#333,color:#fff
    style Nolan fill:#7bc67e,stroke:#333,color:#000
    style KAI fill:#d97b4a,stroke:#333,color:#fff
    style A1 fill:#9b59b6,stroke:#333,color:#fff
    style A2 fill:#9b59b6,stroke:#333,color:#fff
    style A3 fill:#9b59b6,stroke:#333,color:#fff
    style AN fill:#9b59b6,stroke:#333,color:#fff,stroke-dasharray: 5 5
